{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$env:USERPROFILE\\motto-skills\\hooks\\sync-knowledge.ps1\" 2>$null; exit 0",
            "timeout": 30
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"$env:USERPROFILE\\motto-skills\\hooks\\sync-knowledge.ps1\" 2>$null; exit 0",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
